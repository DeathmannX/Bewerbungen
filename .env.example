# GitHub API Konfiguration (Beispiel)
# Kopiere diese Datei nach .env und trage deine echten Daten ein.

# Dein Google Gemini API Key (von https://aistudio.google.com/)
GEMINI_API_KEY=dein_api_key_hier

# Das zu verwendende Modell (z.B. gemini-1.5-flash oder gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash

# Maximale Upload-Größe in Bytes (Standard: 5MB)
MAX_UPLOAD_SIZE_BYTES=5242880

# CORS Einstellungen für die API
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
